# Copy this file to .env.web and edit as needed.
#
# Public-facing URLs for the web client. Replace `localhost` with your
# domain in production (e.g. https://chat.example.com).

# Base host used by the web client.
HOSTNAME=http://localhost

# Public API base URL (passed to the backend so it advertises the right URL).
REVOLT_PUBLIC_URL=http://localhost/api

# Endpoints the web client connects to.
VITE_API_URL=http://localhost/api
VITE_WS_URL=ws://localhost/ws
VITE_MEDIA_URL=http://localhost/autumn
VITE_PROXY_URL=http://localhost/january

# Feature flags.
VITE_CFG_ENABLE_VIDEO=true
